generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  notificationPreferences NotificationPreferences?
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  target    String?
  metadata  String?
  createdAt DateTime @default(now())
}

model Website {
  id         String   @id @default(cuid())
  domain     String   @unique
  rootPath   String
  phpVersion String?
  ssl        Boolean  @default(false)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  wpSite     WpSite?
}

model WpCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#10b981")
  builtIn   Boolean  @default(false)
  sites     WpSite[]
  createdAt DateTime @default(now())
}

model WpSite {
  id           String      @id @default(cuid())
  websiteId    String      @unique
  website      Website     @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  categoryId   String?
  category     WpCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  template     String      @default("blog") // blog | ecommerce | landing
  version      String?
  adminUser    String
  adminEmail   String
  dbName       String
  dbUser       String
  language     String      @default("es_MX")
  pluginsCount Int         @default(0)
  themesCount  Int         @default(0)
  diskUsageMB  Int         @default(0)
  lastSyncAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([categoryId])
}

model Database {
  id        String   @id @default(cuid())
  name      String   @unique
  user      String
  host      String   @default("localhost")
  size      Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model NotificationChannel {
  id        String   @id @default(cuid())
  type      String   // whatsapp | telegram | slack
  name      String
  config    String   // JSON con webhook/token/chatId
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model MailDomain {
  id        String   @id @default(cuid())
  domain    String   @unique
  dkim      String?
  spf       String?
  dmarc     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MailAccount {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  quotaMB   Int      @default(500)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MailAlias {
  id          String   @id @default(cuid())
  source      String   @unique
  destination String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model DnsProvider {
  id          String    @id @default(cuid())
  type        String    // bind | cloudflare | route53 | godaddy | namecheap | namesilo | porkbun
  alias       String
  account     String?   // display only — email, "API Token", etc
  config      String    @default("{}") // JSON con credenciales
  status      Boolean   @default(true)
  permission  String    @default("global") // "global" o JSON con dominios
  isBuiltIn   Boolean   @default(false)
  zones       DnsZone[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model DnsZone {
  id          String       @id @default(cuid())
  domain      String       @unique
  providerId  String?
  provider    DnsProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  primaryNs   String       @default("ns1.localhost.")
  adminEmail  String       @default("admin.localhost.")
  serial      Int          @default(1)
  refresh     Int          @default(3600)
  retry       Int          @default(1800)
  expire      Int          @default(1209600)
  minimum     Int          @default(86400)
  defaultTtl  Int          @default(3600)
  active      Boolean      @default(true)
  records     DnsRecord[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([providerId])
}

model DnsRecord {
  id        String   @id @default(cuid())
  zoneId    String
  zone      DnsZone  @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  type      String
  name      String
  value     String
  ttl       Int      @default(3600)
  priority  Int?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([zoneId])
}

model FirewallRule {
  id        String   @id @default(cuid())
  kind      String   @default("port") // port | ip | forward | area
  protocol  String   @default("tcp")  // tcp | udp | both | icmp
  port      String?                    // "80", "39000:40000"
  sourceIp  String?                    // "all", CIDR, o IP
  destIp    String?                    // para forwards
  destPort  String?                    // para forwards
  country   String?                    // para area rules (ISO code)
  direction String   @default("inbound") // inbound | outbound
  strategy  String   @default("allow") // allow | deny
  remark    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind])
}

model IntrusionScan {
  id             String    @id @default("singleton")
  lastScanAt     DateTime?
  durationMs     Int       @default(0)
  status         String    @default("idle") // idle | running | done | error
  error          String?
  totalFindings  Int       @default(0)
  updatedAt      DateTime  @updatedAt
}

model IntrusionBaseline {
  id        String   @id @default(cuid())
  path      String   @unique
  sha256    String
  size      Int      @default(0)
  mtime     DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IntrusionFinding {
  id          String   @id @default(cuid())
  type        String   // file-change | suspicious-process | unusual-port | rootkit | recent-change
  severity    String   @default("medium")
  title       String
  description String?
  path        String?
  extra       String?  // JSON
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([resolved])
}

model WebsiteSecurityScan {
  id              String    @id @default("singleton")
  score           Int       @default(0)
  durationMs      Int       @default(0)
  xssCount        Int       @default(0)
  sqlCount        Int       @default(0)
  maliciousCount  Int       @default(0)
  phpAttackCount  Int       @default(0)
  topIps          String    @default("[]") // JSON: [{ip, visits}]
  lastScanAt      DateTime?
  status          String    @default("idle") // idle | running | done | error
  error           String?
  updatedAt       DateTime  @updatedAt
}

model WebsiteSecurityRisk {
  id           String   @id @default(cuid())
  category     String   // config | file-leak | webshell | backup | weak-password | logs
  severity     String   @default("medium") // low | medium | high
  title        String
  description  String?
  affectedPath String?
  domain       String?
  resolved     Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([category])
}

model PanelSecuritySettings {
  id                  String   @id @default("singleton")
  alertOnSshLogin     Boolean  @default(false)
  alertOnPanelLogin   Boolean  @default(false)
  totpEnabled         Boolean  @default(false)
  unauthStatusCode    Int      @default(404)
  sslEnabled          Boolean  @default(false)
  updatedAt           DateTime @updatedAt
}

model FirewallSettings {
  id          String   @id @default("singleton")
  enabled     Boolean  @default(false)
  blockIcmp   Boolean  @default(false)
  sshPort     Int      @default(22)
  updatedAt   DateTime @updatedAt
}

model NotificationPreferences {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Email settings
  email                 Boolean  @default(true)
  emailAddress          String?
  
  // Telegram settings
  telegram              Boolean  @default(false)
  telegramChatId        String?
  telegramBotToken      String?
  
  // WhatsApp settings (Twilio)
  whatsapp              Boolean  @default(false)
  whatsappPhone         String?
  twilioAccountSid      String?
  twilioAuthToken       String?
  twilioPhoneNumber     String?
  
  // Slack settings
  slack                 Boolean  @default(false)
  slackWebhook          String?
  
  // SendGrid settings
  sendgridApiKey        String?
  sendgridFromEmail     String?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
model SshServer {
  id         String   @id @default(cuid())
  host       String
  port       Int      @default(22)
  username   String   @default("root")
  authType   String   @default("password") // password | key
  password   String?
  privateKey String?
  remarks    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SshCommand {
  id        String   @id @default(cuid())
  name      String
  command   String
  createdAt DateTime @default(now())
}
